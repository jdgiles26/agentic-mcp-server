{
  "name": "@prompt-forge/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "promptforge-mcp": "./bin/stdio.mjs",
    "promptforge-mcp-http": "./bin/http.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start:stdio": "tsx src/stdio.ts",
    "start:http": "tsx src/http.ts"
  },
  "dependencies": {
    "@prompt-forge/core": "workspace:*",
    "@prompt-forge/enhancer": "workspace:*",
    "@prompt-forge/patterns": "workspace:*",
    "@prompt-forge/providers": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
